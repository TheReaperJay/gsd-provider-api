{
  "name": "@thereaperjay/gsd-provider-api",
  "version": "0.4.3",
  "description": "Provider contracts, registries, discovery, onboarding, and Pi adapter for GSD-compatible provider extensions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheReaperJay/gsd-provider-api.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "gsd",
    "provider",
    "plugin",
    "adapter",
    "pi"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@mariozechner/jiti": "^2.6.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "gsd-pi": "^2.43.0",
    "typescript": "^5.6.3",
    "zod": "^3.24.1"
  }
}
